server {
    server_name grid.niteride.fm;

    # Federation prefix 404s.
    # Lemmy fork has ActivityPub compiled but runtime-disabled
    # (federation.enabled=false in lemmy.hjson). External federation endpoints
    # must still 404 at the edge to reduce attack surface. See
    # engineering/platforms/grid-fork-deltas.md "Compiled-but-disabled
    # ActivityPub" and invariants.md.
    location ~ ^/(inbox|outbox|nodeinfo|\.well-known/nodeinfo) {
        return 404;
    }
    location ~ ^/api/v3/(activity|federation) {
        return 404;
    }

    location / {
        proxy_pass http://127.0.0.1:8536;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/grid.niteride.fm/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/grid.niteride.fm/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = grid.niteride.fm) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name grid.niteride.fm;
    return 404; # managed by Certbot


}