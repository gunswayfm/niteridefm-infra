server {
    listen 443 ssl http2;
    # Nginx configuration for v2.niteride.fm (React SPA + API Proxy)
    server_name v2.niteride.fm api-v2.niteride.fm;

    # SSL configuration
    ssl_certificate /etc/letsencrypt/live/v2.niteride.fm/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/v2.niteride.fm/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Logging
    access_log /var/log/nginx/v2-access.log;
    error_log /var/log/nginx/v2-error.log warn;

    # API proxy
    location /api/v1 {
        # CSP for API
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.niteride.fm https://cdn.niteride.fm https://*.supabase.co; media-src 'self' https://cdn.niteride.fm; frame-src 'self' https://niteride.fm https://admin.niteride.fm;" always;

        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Grid API proxy (The Grid)
    location /grid-api/ {
        proxy_pass http://82.22.53.68:1236/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }


    # Frontend - React SPA (v2)
        location / {
        # CSP for Frontend
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.niteride.fm https://api-v2.niteride.fm https://cdn.niteride.fm https://*.supabase.co; media-src 'self' https://cdn.niteride.fm; frame-src 'self' https://niteride.fm https://admin.niteride.fm;" always;

        root /opt/niteride/services/web/frontend/dist;
        try_files $uri $uri/ /index.html;

        location = /index.html {
            add_header Cache-Control "no-store, no-cache, must-revalidate";
            # Inherit CSP
            add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.niteride.fm https://api-v2.niteride.fm https://cdn.niteride.fm https://*.supabase.co; media-src 'self' https://cdn.niteride.fm; frame-src 'self' https://niteride.fm https://admin.niteride.fm;" always;
        }

        location ~ "\.[a-f0-9]\{8,\}\.(js|css)$" {
            expires 1y;
            add_header Cache-Control "public, immutable";
             # Inherit CSP
            add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.niteride.fm https://api-v2.niteride.fm https://cdn.niteride.fm https://*.supabase.co; media-src 'self' https://cdn.niteride.fm; frame-src 'self' https://niteride.fm https://admin.niteride.fm;" always;
        }

        location ~* \.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 7d;
            add_header Cache-Control "public";
        }
    }
}

server {
    listen 80;
    server_name v2.niteride.fm;
    return 301 https://v2.niteride.fm$request_uri;
}
